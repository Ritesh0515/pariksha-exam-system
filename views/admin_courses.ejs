<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Manage Courses | Pariksha Admin</title>
    <style>
        .glass-card { transition: all 0.3s ease; }
        
        /* Updated to match your Midnight Blue theme */
        .course-badge {
            background-color: #E0E7FF; 
            color: var(--primary-blue);
            font-weight: 600;
            padding: 6px 14px;
            border-radius: 8px;
            display: inline-block;
        }

        /* Ensuring the top border uses your theme color, not default Bootstrap blue */
        .theme-border-top {
            border-top: 4px solid var(--primary-blue) !important;
        }
    </style>
</head>
<body class="bg-light">
<div class="container-fluid px-0">
    <div class="row g-0">
        <%- include('partials/sidebar', {currentPage: 'courses'}) %>

        <div class="col-12 col-md-10 offset-md-2 p-3 p-md-5">
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold text-dark mb-1">Course Management</h2>
                    <p class="text-muted small mb-0">Add and manage main academic departments (BBA, BBA-CA, MBA, etc.).</p>
                </div>
            </div>

            <% if (user.role !== 'staff') { %>
            <div class="card glass-card p-4 border-0 shadow-sm theme-border-top mb-5">
                <h5 class="fw-bold mb-3">Add New Course</h5>
                <form action="/admin/courses/add" method="POST" class="row g-3">
                    <div class="col-md-9">
                        <input type="text" name="course_name" class="form-control bg-light border-0 p-3" placeholder="e.g. BBA-CA" required>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary w-100 shadow-sm fw-bold p-3">
                            <i class="bi bi-plus-lg me-2"></i>Add Course
                        </button>
                    </div>
                </form>
            </div>
            <% } %>

            <div class="card border-0 shadow-sm overflow-hidden rounded-4">
                <div class="table-responsive">
                    <table class="table mb-0 align-middle table-hover bg-white">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4 py-3 text-muted fw-semibold">Course ID</th>
                                <th class="py-3 text-muted fw-semibold">Course Name</th>
                                <th class="text-end pe-4 py-3 text-muted fw-semibold">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (courses.length > 0) { %>
                                <% courses.forEach(c => { %>
                                <tr>
                                    <td class="ps-4 text-muted small">#<%= c.course_id %></td>
                                    
                                    <td><span class="course-badge"><%= c.course_name %></span></td>
                                    
                                    <td class="text-end pe-4">
                                        <% if (user.role !== 'staff') { %>
                                            <button class="btn btn-sm btn-outline-danger px-3 rounded-pill" 
                                                onclick="handleCourseDelete('<%= c.course_id %>')">
                                                <i class="bi bi-trash me-1"></i>Delete
                                            </button>
                                        <% } else { %>
                                            <span class="badge bg-secondary-subtle text-secondary rounded-pill px-3 py-2">View Only</span>
                                        <% } %>
                                    </td>
                                </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="3" class="text-center py-5">
                                        <div class="text-muted">
                                            <i class="bi bi-inbox fs-1 d-block mb-2 text-opacity-50"></i>
                                            <p class="mb-0">No courses added yet.</p>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
            
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function handleCourseDelete(id) {
        Swal.fire({
            title: 'Delete Course?',
            text: "This is a critical action! It will affect all subjects and exams linked to this course.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Yes, delete it!'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/admin/courses/delete/' + id;
            }
        });
    }
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>