<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Manage Exams | Pariksha Admin</title>
    <style>
        .glass-card { transition: all 0.3s ease; border-radius: 12px; }
        .badge-course { background-color: #E0E7FF; color: var(--primary-blue); font-weight: 600; }
        .chained-select:disabled { background-color: #e2e8f0 !important; cursor: not-allowed; opacity: 0.7; }
        .theme-border-top { border-top: 4px solid var(--primary-blue) !important; }
        input[type="datetime-local"] { color: #334155; font-weight: 500; }
    </style>
</head>
<body class="bg-light">

<div class="container-fluid px-0">
    <div class="row g-0">
        <%- include('partials/sidebar', {currentPage: 'exams'}) %>

        <div class="col-12 col-md-10 offset-md-2 p-3 p-md-5">
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold text-dark mb-0">Exam Management</h2>
                    <p class="text-muted small">Create and organize exams by Course, Year, and Subject.</p>
                </div>
                <% if (user.role !== 'staff') { %>
                <button class="btn btn-primary shadow-sm rounded-pill px-4" data-bs-toggle="collapse" data-bs-target="#addExamForm">
                    <i class="bi bi-plus-lg me-2"></i>Create New Exam
                </button>
                <% } %>
            </div>

            <div class="collapse mb-4" id="addExamForm">
                <div class="card glass-card p-4 border-0 shadow-sm theme-border-top">
                    <h5 class="fw-bold mb-3">Exam Configuration</h5>
                    <form action="/admin/exams/add" method="POST" class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">1. Select Course</label>
                            <select id="courseSelect" class="form-select border-0 bg-light p-2" required>
                                <option value="" selected disabled>Choose Course...</option>
                                <% courses.forEach(c => { %>
                                    <option value="<%= c.course_id %>"><%= c.course_name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">2. Academic Year</label>
                            <select id="yearSelect" class="form-select border-0 bg-light p-2 chained-select" required disabled>
                                <option value="" selected disabled>Choose Year...</option>
                                <option value="FY">FY</option>
                                <option value="SY">SY</option>
                                <option value="TY">TY</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">3. Select Subject</label>
                            <select name="subject_id" id="subjectSelect" class="form-select border-0 bg-light p-2 chained-select" required disabled>
                                <option value="" selected disabled>Waiting for Year...</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">4. Exam Title</label>
                            <input type="text" name="exam_name" class="form-control border-0 bg-light p-2" required>
                        </div>
                        <div class="col-md-2">
                            <label class="small fw-bold">Duration (Min)</label>
                            <input type="number" name="duration_minutes" class="form-control bg-light border-0" required>
                        </div>
                        <div class="col-md-2">
                            <label class="small fw-bold">Pass Marks</label>
                            <input type="number" name="pass_marks" class="form-control bg-light border-0" required>
                        </div>
                        <div class="col-md-2">
                            <label class="small fw-bold">Total Marks</label>
                            <input type="number" name="total_marks" class="form-control bg-light border-0" required>
                        </div>
                        <div class="col-md-3">
                            <label class="small fw-bold text-primary">Start Time</label>
                            <input type="datetime-local" name="start_time" class="form-control bg-light border-0" required>
                        </div>
                        <div class="col-md-3">
                            <label class="small fw-bold text-danger">End Time</label>
                            <input type="datetime-local" name="end_time" class="form-control bg-light border-0" required>
                        </div>
                        <div class="col-12 text-end mt-4">
                            <button type="submit" class="btn btn-primary px-5 rounded-pill fw-bold shadow-sm">Save Configuration</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card glass-card border-0 shadow-sm overflow-hidden rounded-4">
                <div class="table-responsive">
                    <table class="table mb-0 align-middle table-hover">
                        <thead class="bg-light text-uppercase small text-muted fw-semibold">
                            <tr>
                                <th class="ps-4 py-3">Exam Details</th>
                                <th>Schedule</th>
                                <th>Academic Info</th>
                                <th>Stats</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (exams && exams.length > 0) { %>
                                <% exams.forEach(exam => { %>
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold text-dark"><%= exam.exam_name %></div>
                                        <div class="text-muted small">ID: #<%= exam.exam_id %></div>
                                    </td>
                                    <td>
                                        <div class="small text-dark fw-semibold">
                                            <i class="bi bi-play-circle text-primary me-1"></i> 
                                            <%= exam.start_time ? new Date(exam.start_time).toLocaleString([], {dateStyle: 'short', timeStyle: 'short'}) : 'Not Set' %>
                                        </div>
                                        <div class="small text-muted">
                                            <i class="bi bi-stop-circle text-danger me-1"></i> 
                                            <%= exam.end_time ? new Date(exam.end_time).toLocaleString([], {dateStyle: 'short', timeStyle: 'short'}) : 'Not Set' %>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="fw-semibold text-dark mb-1"><%= exam.subject_name %></div>
                                        <span class="badge badge-course px-2 py-1"><%= exam.course_name %> | <%= exam.year %></span>
                                    </td>
                                    <td>
                                        <div class="small text-dark"><i class="bi bi-clock me-1 text-muted"></i><%= exam.duration_minutes %>m</div>
                                        <div class="small text-dark"><i class="bi bi-award me-1 text-muted"></i><%= exam.pass_marks %>/<%= exam.total_marks %></div>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group shadow-sm rounded-3 overflow-hidden">
                                            <a href="/admin/exams/<%= exam.exam_id %>/questions" class="btn btn-sm btn-light border" title="Questions">
                                                <i class="bi bi-list-check" style="color: var(--primary-blue);"></i>
                                            </a>
                                            <button class="btn btn-sm btn-light border edit-btn" 
                                                title="Edit" 
                                                data-id="<%= exam.exam_id %>"
                                                data-name="<%= exam.exam_name %>"
                                                data-duration="<%= exam.duration_minutes %>"
                                                data-total="<%= exam.total_marks %>"
                                                data-pass="<%= exam.pass_marks %>"
                                                data-start="<%= exam.start_time %>"
                                                data-end="<%= exam.end_time %>">
                                                <i class="bi bi-pencil text-secondary"></i>
                                            </button>
                                            <button class="btn btn-sm btn-light border" title="Delete" 
                                                onclick="handleDelete('<%= exam.exam_id %>', '<%= user.role %>')">
                                                <i class="bi bi-trash text-danger"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editExamModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header text-white border-0 py-3" style="background-color: var(--primary-blue);">
                <h5 class="modal-title fw-bold">Edit Exam Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="editExamForm" method="POST">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Exam Title</label>
                        <input type="text" name="exam_name" id="edit_exam_name" class="form-control bg-light border-0 p-2" required>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold small">Duration (Min)</label>
                            <input type="number" name="duration_minutes" id="edit_duration" class="form-control bg-light border-0 p-2" required>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold small">Pass Marks</label>
                            <input type="number" name="pass_marks" id="edit_pass_marks" class="form-control bg-light border-0 p-2" required>
                        </div>
                        <div class="col-12 mb-3">
                            <label class="form-label fw-bold small">Total Marks</label>
                            <input type="number" name="total_marks" id="edit_total_marks" class="form-control bg-light border-0 p-2" required>
                        </div>
                        <div class="col-12 mb-3">
                            <label class="form-label fw-bold small">Start Time</label>
                            <input type="datetime-local" name="start_time" id="edit_start_time" class="form-control bg-light border-0 p-2" required>
                        </div>
                        <div class="col-12 mb-3">
                            <label class="form-label fw-bold small">End Time</label>
                            <input type="datetime-local" name="end_time" id="edit_end_time" class="form-control bg-light border-0 p-2" required>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold py-2">Update Configuration</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // 1. Chained Dropdowns
    const courseSelect = document.getElementById('courseSelect');
    const yearSelect = document.getElementById('yearSelect');
    const subjectSelect = document.getElementById('subjectSelect');

    if (courseSelect) {
        courseSelect.addEventListener('change', () => {
            yearSelect.disabled = false;
            yearSelect.value = ""; 
            subjectSelect.disabled = true;
            subjectSelect.innerHTML = '<option value="" selected disabled>Select Year first...</option>';
        });
    }

    if (yearSelect) {
        yearSelect.addEventListener('change', async () => {
            const courseId = courseSelect.value;
            const year = yearSelect.value;
            if (!courseId || !year) return;
            try {
                const response = await fetch(`/api/subjects-filter?course_id=${courseId}&year=${year}`);
                const subjects = await response.json();
                subjectSelect.innerHTML = '<option value="" selected disabled>Select Subject...</option>';
                subjects.forEach(sub => {
                    const opt = document.createElement('option');
                    opt.value = sub.subject_id; opt.text = sub.subject_name;
                    subjectSelect.add(opt);
                });
                subjectSelect.disabled = false;
            } catch (err) { console.error(err); }
        });
    }

    // 2. FIXED: Bulletproof Edit Modal Logic
    document.querySelectorAll('.edit-btn').forEach(button => {
        button.addEventListener('click', function() {
            const id = this.getAttribute('data-id');
            const name = this.getAttribute('data-name');
            const duration = this.getAttribute('data-duration');
            const total = this.getAttribute('data-total');
            const pass = this.getAttribute('data-pass');
            const start = this.getAttribute('data-start');
            const end = this.getAttribute('data-end');

            document.getElementById('edit_exam_name').value = name;
            document.getElementById('edit_duration').value = duration;
            document.getElementById('edit_total_marks').value = total; 
            document.getElementById('edit_pass_marks').value = pass;
            document.getElementById('editExamForm').action = '/admin/exams/update/' + id;

            const formatForInput = (dateStr) => {
                if (!dateStr || dateStr === 'null' || dateStr === 'undefined') return "";
                const d = new Date(dateStr);
                if (isNaN(d.getTime())) return "";
                d.setMinutes(d.getMinutes() - d.getTimezoneOffset());
                return d.toISOString().slice(0, 16);
            };

            document.getElementById('edit_start_time').value = formatForInput(start);
            document.getElementById('edit_end_time').value = formatForInput(end);
            
            new bootstrap.Modal(document.getElementById('editExamModal')).show();
        });
    });

    // 3. Delete Handler
    function handleDelete(examId, userRole) {
        if (userRole === 'staff') {
            Swal.fire({ icon: 'warning', title: 'Denied', text: 'Staff cannot delete exams.', confirmButtonColor: '#1E3A8A' });
            return;
        }
        Swal.fire({
            title: 'Delete Exam?',
            text: "This removes questions, but preserves results.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            confirmButtonText: 'Yes, delete it!'
        }).then((result) => {
            if (result.isConfirmed) window.location.href = '/admin/exams/delete/' + examId;
        });
    }
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>