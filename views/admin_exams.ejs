<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Manage Exams | Pariksha Admin</title>
    <style>
        .glass-card { transition: all 0.3s ease; border-radius: 12px; }
        
        /* Updated badge to match the theme used in Courses */
        .badge-course { 
            background-color: #E0E7FF; 
            color: var(--primary-blue); 
            font-weight: 600;
        }
        
        .chained-select:disabled { 
            background-color: #e2e8f0 !important; 
            cursor: not-allowed; 
            opacity: 0.7;
        }

        .theme-border-top {
            border-top: 4px solid var(--primary-blue) !important;
        }
    </style>
</head>
<body class="bg-light">

<div class="container-fluid px-0">
    <div class="row g-0">
        <%- include('partials/sidebar', {currentPage: 'exams'}) %>

        <div class="col-12 col-md-10 offset-md-2 p-3 p-md-5">
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold text-dark mb-0">Exam Management</h2>
                    <p class="text-muted small">Create and organize exams by Course, Year, and Subject.</p>
                </div>
                <% if (user.role !== 'staff') { %>
                <button class="btn btn-primary shadow-sm rounded-pill px-4" data-bs-toggle="collapse" data-bs-target="#addExamForm">
                    <i class="bi bi-plus-lg me-2"></i>Create New Exam
                </button>
                <% } %>
            </div>

            <div class="collapse mb-4" id="addExamForm">
                <div class="card glass-card p-4 border-0 shadow-sm theme-border-top">
                    <h5 class="fw-bold mb-3">Exam Configuration</h5>
                    <form action="/admin/exams/add" method="POST" class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">1. Select Course</label>
                            <select id="courseSelect" class="form-select border-0 bg-light p-2" required>
                                <option value="" selected disabled>Choose Course...</option>
                                <% courses.forEach(c => { %>
                                    <option value="<%= c.course_id %>"><%= c.course_name %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label small fw-bold">2. Academic Year</label>
                            <select id="yearSelect" class="form-select border-0 bg-light p-2 chained-select" required disabled>
                                <option value="" selected disabled>Choose Year...</option>
                                <option value="FY">FY</option>
                                <option value="SY">SY</option>
                                <option value="TY">TY</option>
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label small fw-bold">3. Select Subject</label>
                            <select name="subject_id" id="subjectSelect" class="form-select border-0 bg-light p-2 chained-select" required disabled>
                                <option value="" selected disabled>Waiting for Year...</option>
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label small fw-bold">4. Exam Title</label>
                            <input type="text" name="exam_name" class="form-control border-0 bg-light p-2" placeholder="e.g. Unit Test 1" required>
                        </div>

                        <div class="col-md-4">
                            <label class="small fw-bold">Duration (Mins)</label>
                            <input type="number" name="duration_minutes" class="form-control bg-light border-0" placeholder="60" required>
                        </div>
                        <div class="col-md-4">
                            <label class="small fw-bold">Total Marks</label>
                            <input type="number" name="total_marks" class="form-control bg-light border-0" placeholder="100" required>
                        </div>
                        <div class="col-md-4">
                            <label class="small fw-bold">Pass Marks</label>
                            <input type="number" name="pass_marks" class="form-control bg-light border-0" placeholder="40" required>
                        </div>

                        <div class="col-12 text-end mt-4">
                            <button type="submit" class="btn btn-primary px-5 rounded-pill fw-bold shadow-sm">Save Exam Configuration</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card glass-card border-0 shadow-sm overflow-hidden rounded-4">
                <div class="table-responsive">
                    <table class="table mb-0 align-middle table-hover">
                        <thead class="bg-light text-uppercase small text-muted fw-semibold">
                            <tr>
                                <th class="ps-4 py-3">Exam Details</th>
                                <th>Academic Info</th>
                                <th>Stats</th>
                                <th>Status</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (exams && exams.length > 0) { %>
                                <% exams.forEach(exam => { %>
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold text-dark"><%= exam.exam_name %></div>
                                        <div class="text-muted small">ID: #<%= exam.exam_id %></div>
                                    </td>
                                    <td>
                                        <div class="fw-semibold text-dark mb-1"><%= exam.subject_name %></div>
                                        <span class="badge badge-course px-2 py-1"><%= exam.course_name %> | <%= exam.year %></span>
                                    </td>
                                    <td>
                                        <div class="small text-dark"><i class="bi bi-clock me-1 text-muted"></i><%= exam.duration_minutes %>m</div>
                                        <div class="small text-dark"><i class="bi bi-award me-1 text-muted"></i><%= exam.pass_marks %>/<%= exam.total_marks %> Pass</div>
                                    </td>
                                    <td><span class="badge bg-success-subtle text-success rounded-pill px-3 py-2">Active</span></td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group shadow-sm rounded-3 overflow-hidden">
                                            <a href="/admin/exams/<%= exam.exam_id %>/questions" class="btn btn-sm btn-light border" title="Questions">
                                                <i class="bi bi-list-check" style="color: var(--primary-blue);"></i>
                                            </a>
                                            <button class="btn btn-sm btn-light border" title="Edit" 
                                                onclick="openEditModal('<%= exam.exam_id %>', '<%= exam.exam_name %>', '<%= exam.duration_minutes %>', '<%= exam.total_marks %>', '<%= exam.pass_marks %>')">
                                                <i class="bi bi-pencil text-secondary"></i>
                                            </button>
                                            <button class="btn btn-sm btn-light border" title="Delete" 
                                                onclick="handleDelete('<%= exam.exam_id %>', '<%= user.role %>')">
                                                <i class="bi bi-trash text-danger"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center py-5">
                                        <div class="text-muted">
                                            <i class="bi bi-journal-x fs-1 d-block mb-2 text-opacity-50"></i>
                                            <p class="mb-0">No exams configured yet.</p>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
            
        </div>
    </div>
</div>

<div class="modal fade" id="editExamModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header text-white border-0 py-3" style="background-color: var(--primary-blue);">
                <h5 class="modal-title fw-bold">Edit Exam Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="editExamForm" method="POST">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Exam Title</label>
                        <input type="text" name="exam_name" id="edit_exam_name" class="form-control bg-light border-0 p-2" required>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold small">Duration (Min)</label>
                            <input type="number" name="duration_minutes" id="edit_duration" class="form-control bg-light border-0 p-2" required>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold small">Pass Marks</label>
                            <input type="number" name="pass_marks" id="edit_pass_marks" class="form-control bg-light border-0 p-2" required>
                        </div>
                        <div class="col-12 mb-3">
                            <label class="form-label fw-bold small">Total Marks</label>
                            <input type="number" name="total_marks" id="edit_total_marks" class="form-control bg-light border-0 p-2" required>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold py-2">Update Configuration</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const urlParams = new URLSearchParams(window.location.search);

    // 1. Chained Dropdown Logic
    const courseSelect = document.getElementById('courseSelect');
    const yearSelect = document.getElementById('yearSelect');
    const subjectSelect = document.getElementById('subjectSelect');

    if (courseSelect) {
        courseSelect.addEventListener('change', () => {
            yearSelect.disabled = false;
            yearSelect.value = ""; 
            subjectSelect.disabled = true;
            subjectSelect.innerHTML = '<option value="" selected disabled>Select Year first...</option>';
        });
    }

    if (yearSelect) {
        yearSelect.addEventListener('change', async () => {
            const courseId = courseSelect.value;
            const year = yearSelect.value;
            if (!courseId || !year) return;
            try {
                const response = await fetch(`/api/subjects-filter?course_id=${courseId}&year=${year}`);
                const subjects = await response.json();
                subjectSelect.innerHTML = '<option value="" selected disabled>Select Subject...</option>';
                if (subjects.length > 0) {
                    subjects.forEach(sub => {
                        const opt = document.createElement('option');
                        opt.value = sub.subject_id;
                        opt.text = sub.subject_name;
                        subjectSelect.add(opt);
                    });
                    subjectSelect.disabled = false;
                } else {
                    subjectSelect.innerHTML = '<option value="" selected disabled>No subjects found</option>';
                }
            } catch (err) { console.error("Fetch Error:", err); }
        });
    }

    // 2. Edit Modal Logic
    function openEditModal(id, name, duration, total, pass) {
        document.getElementById('edit_exam_name').value = name;
        document.getElementById('edit_duration').value = duration;
        document.getElementById('edit_total_marks').value = total; 
        document.getElementById('edit_pass_marks').value = pass;
        document.getElementById('editExamForm').action = '/admin/exams/update/' + id;
        
        const myModal = new bootstrap.Modal(document.getElementById('editExamModal'));
        myModal.show();
    }

    // 3. Smart Deletion Logic (Frontend Guard)
    function handleDelete(examId, userRole) {
        if (userRole === 'staff') {
            Swal.fire({
                icon: 'warning',
                title: 'Permission Denied',
                text: 'As a Staff member, you do not have authority to delete exams. Please contact an Admin.',
                confirmButtonColor: '#1E3A8A' // Matched to theme
            });
            return;
        }

        Swal.fire({
            title: 'Are you sure?',
            text: "This will remove the exam and its questions, but student results will be preserved.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#1E3A8A', // Matched to theme
            confirmButtonText: 'Yes, delete it!'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/admin/exams/delete/' + examId;
            }
        });
    }

    // 4. Success Alert Handling
    if (urlParams.get('success') === 'deleted') {
        Swal.fire({ icon: 'success', title: 'Deleted!', text: 'The exam was removed successfully.', timer: 2000, showConfirmButton: false });
    }
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>