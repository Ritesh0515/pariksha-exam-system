<%- include('partials/head') %>

    <body class="bg-light">
        <div class="container-fluid">
            <div class="row">
                <%- include('partials/sidebar', {currentPage: 'students' }) %>
                    <div class="col-md-10 offset-md-2 p-5">
                        <h2 class="fw-bold mb-4">Student Management</h2>

                        <!-- Breadcrumb -->
                        <nav aria-label="breadcrumb" class="mb-4">
                            <ol class="breadcrumb bg-white p-3 rounded-3 shadow-sm" id="breadcrumb">
                                <li class="breadcrumb-item active" aria-current="page">Students</li>
                            </ol>
                        </nav>

                        <!-- Course View -->
                        <div id="courseView" class="row g-4">
                            <% courses.forEach(c=> { %>
                                <div class="col-md-4">
                                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden course-card"
                                        data-course="<%= c.course_name %>"
                                        onclick="selectCourse('<%= c.course_name %>')">
                                        <div class="card-body text-center p-5">
                                            <h3 class="card-title fw-bold text-primary">
                                                <%= c.course_name %>
                                            </h3>
                                            <p class="card-text text-muted">Click to view years</p>
                                        </div>
                                    </div>
                                </div>
                                <% }) %>
                        </div>

                        <!-- Year View -->
                        <div id="yearView" class="d-none">
                            <div class="text-center">
                                <h4 class="fw-bold mb-4">Select Year</h4>
                                <div class="row g-3 justify-content-center">
                                    <div class="col-md-3">
                                        <button class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm"
                                            onclick="selectYear('FY')">FY</button>
                                    </div>
                                    <div class="col-md-3">
                                        <button class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm"
                                            onclick="selectYear('SY')">SY</button>
                                    </div>
                                    <div class="col-md-3">
                                        <button class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm"
                                            onclick="selectYear('TY')">TY</button>
                                    </div>
                                </div>
                                <button class="btn btn-outline-secondary mt-4 rounded-pill px-4"
                                    onclick="goBackToCourses()">Back to Courses</button>
                            </div>
                        </div>

                        <!-- Student View -->
                        <div id="studentView" class="d-none">
                            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                                <div class="p-4 bg-light border-bottom">
                                    <div class="row g-3 align-items-end">
                                        <div class="col-md-6">
                                            <label class="form-label small fw-bold">SEARCH</label>
                                            <input id="searchFilter" type="text"
                                                class="form-control bg-white border-0 shadow-sm"
                                                placeholder="Enter name or email">
                                        </div>
                                        <div class="col-md-3">
                                            <button id="resetFilters"
                                                class="btn btn-outline-secondary w-100">Reset</button>
                                        </div>
                                        <div class="col-md-3">
                                            <button class="btn btn-outline-primary w-100" onclick="goBackToYears()">Back
                                                to Years</button>
                                        </div>
                                    </div>
                                </div>
                                <table class="table mb-0 align-middle table-hover bg-white">
                                    <thead class="bg-light text-muted small">
                                        <tr>
                                            <th class="ps-4 py-3">ROLL NO</th>
                                            <th>STUDENT DETAILS</th>
                                            <th class="text-end pe-4">ACTIONS</th>
                                        </tr>
                                    </thead>
                                    <tbody id="studentTableBody">
                                        <% students.forEach(s=> { %>
                                            <tr data-course="<%= s.class_name %>" data-year="<%= s.year_code %>"
                                                data-name="<%= s.first_name %> <%= s.last_name %>"
                                                data-email="<%= s.email %>">
                                                <td class="ps-4">
                                                    <% if (s.roll_no) { %>
                                                        <span class="fw-bold text-primary">#<%= s.roll_no %></span>
                                                        <% } else { %>
                                                            <span class="text-muted">NOT ASSIGNED</span>
                                                            <% } %>
                                                </td>

                                                <td>
                                                    <div class="fw-bold text-dark">
                                                        <%= s.first_name %>
                                                            <%= s.last_name %>
                                                    </div>
                                                    <div class="text-muted small">
                                                        <%= s.email %> • <%= s.year_code %>
                                                                <%= s.class_name %>
                                                    </div>
                                                </td>

                                                <td class="text-end pe-4">
                                                    <button
                                                        class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-sm"
                                                        data-user-id="<%= s.user_id %>" data-roll-no="<%= s.roll_no %>"
                                                        data-full-name="<%= s.first_name %> <%= s.last_name %>"
                                                        data-class-name="<%= s.class_name %>"
                                                        data-year-code="<%= s.year_code %>"
                                                        onclick="openEditModal(this)">
                                                        <i class="bi bi-pencil-square me-1"></i> Update Info
                                                    </button>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
            </div>
        </div>

        <div class="modal fade" id="editRollModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg rounded-4">
                    <div class="modal-header bg-primary text-white border-0">
                        <h5 class="modal-title fw-bold">Update Student Info</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form id="editRollForm" method="POST">
                        <div class="modal-body p-4 text-center">
                            <p class="text-muted">Updating information for <br><strong id="student_display_name"
                                    class="text-dark fs-5"></strong></p>
                            <p id="modal_context_label" class="text-primary fw-bold small mt-2"></p>
                            <div class="text-start mt-3">
                                <label class="form-label small fw-bold text-primary">Course</label>
                                <select name="course" id="modal_course_select" class="form-select bg-light border-0 p-3"
                                    required>
                                    <% courses.forEach(c=> { %>
                                        <option>
                                            <%= c.course_name %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>
                            <div class="text-start mt-3">
                                <label class="form-label small fw-bold text-primary">Year</label>
                                <select name="year" id="modal_year_select" class="form-select bg-light border-0 p-3"
                                    required>
                                    <option>FY</option>
                                    <option>SY</option>
                                    <option>TY</option>
                                </select>
                            </div>
                            <div class="text-start mt-3">
                                <label class="form-label small fw-bold text-primary">Roll Number</label>
                                <input type="number" name="roll_no" id="modal_roll_input"
                                    class="form-control bg-light border-0 p-3" placeholder="e.g. 15" required>
                            </div>
                        </div>
                        <div class="modal-footer border-0 p-4">
                            <button type="button" class="btn btn-light px-4 rounded-pill"
                                data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm rounded-pill">Save
                                Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

        <script>
            // Check for roll number conflict error on page load
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('error') === 'already_taken') {
                Swal.fire({
                    title: 'Roll Number Conflict',
                    text: 'The roll number is already assigned in that specific Class and Year.',
                    icon: 'error',
                    confirmButtonText: 'OK'
                }).then(() => {
                    // Remove the error parameter from URL
                    urlParams.delete('error');
                    const newUrl = window.location.pathname + (urlParams.toString() ? '?' + urlParams.toString() : '');
                    window.history.replaceState(null, null, newUrl);
                });
            }

            let selectedCourse = null;
            let selectedYear = null;

            function updateBreadcrumb() {
                const breadcrumb = document.getElementById('breadcrumb');
                breadcrumb.innerHTML = '<li class="breadcrumb-item"><a href="#" onclick="goBackToCourses()">Students</a></li>';
                if (selectedCourse) {
                    breadcrumb.innerHTML += '<li class="breadcrumb-item active" aria-current="page">' + selectedCourse + '</li>';
                }
                if (selectedYear) {
                    breadcrumb.innerHTML += '<li class="breadcrumb-item active" aria-current="page">' + selectedYear + '</li>';
                }
            }

            function selectCourse(course) {
                selectedCourse = course;
                selectedYear = null;
                document.getElementById('courseView').classList.add('d-none');
                document.getElementById('yearView').classList.remove('d-none');
                document.getElementById('studentView').classList.add('d-none');
                updateBreadcrumb();
            }

            function selectYear(year) {
                selectedYear = year;
                document.getElementById('courseView').classList.add('d-none');
                document.getElementById('yearView').classList.add('d-none');
                document.getElementById('studentView').classList.remove('d-none');
                updateBreadcrumb();
                filterStudentTable();
            }

            function goBackToCourses() {
                selectedCourse = null;
                selectedYear = null;
                document.getElementById('courseView').classList.remove('d-none');
                document.getElementById('yearView').classList.add('d-none');
                document.getElementById('studentView').classList.add('d-none');
                updateBreadcrumb();
            }

            function goBackToYears() {
                selectedYear = null;
                document.getElementById('courseView').classList.add('d-none');
                document.getElementById('yearView').classList.remove('d-none');
                document.getElementById('studentView').classList.add('d-none');
                updateBreadcrumb();
            }

            function openEditModal(button) {
                const id = button.getAttribute('data-user-id');
                const currentRoll = button.getAttribute('data-roll-no');
                const name = button.getAttribute('data-full-name');
                const className = button.getAttribute('data-class-name');
                const yearCode = button.getAttribute('data-year-code');

                // Fix for "null" values coming from DB
                const rollValue = (currentRoll === 'null' || !currentRoll || currentRoll === '') ? '' : currentRoll;

                document.getElementById('editRollForm').action = '/admin/students/update-roll/' + id;
                document.getElementById('student_display_name').innerText = name;
                document.getElementById('modal_context_label').innerText = 'Updating for ' + yearCode + ' ' + className;
                document.getElementById('modal_course_select').value = className;
                document.getElementById('modal_year_select').value = yearCode;
                document.getElementById('modal_roll_input').value = rollValue;

                // Explicitly trigger the modal
                var myModal = new bootstrap.Modal(document.getElementById('editRollModal'));
                myModal.show();
            }

            function filterStudentTable() {
                const searchFilter = document.getElementById('searchFilter').value.toLowerCase();
                const rows = document.querySelectorAll('#studentTableBody tr');

                rows.forEach(row => {
                    const course = row.dataset.course;
                    const year = row.dataset.year;
                    const name = row.dataset.name.toLowerCase();
                    const email = row.dataset.email.toLowerCase();

                    const matchesCourse = course === selectedCourse;
                    const matchesYear = year === selectedYear;
                    const matchesSearch = !searchFilter || name.includes(searchFilter) || email.includes(searchFilter);

                    row.style.display = matchesCourse && matchesYear && matchesSearch ? '' : 'none';
                });
            }

            document.getElementById('searchFilter').addEventListener('input', filterStudentTable);
            document.getElementById('resetFilters').addEventListener('click', function () {
                document.getElementById('searchFilter').value = '';
                filterStudentTable();
            });
        </script>
    </body>

    </html>