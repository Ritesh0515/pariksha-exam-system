<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Login | Pariksha</title>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            /* Updated gradient to match Midnight Blue theme */
            background: linear-gradient(135deg, #0f172a 0%, var(--primary-blue) 100%);
            margin: 0;
            font-family: 'Inter', sans-serif;
        }
        .login-card {
            max-width: 420px;
            width: 90%;
            border-radius: 24px;
            border: none;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            transition: transform 0.3s ease;
        }
        .login-card:hover {
            transform: translateY(-5px);
        }
        .brand-logo {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--primary-blue); /* Themed */
            letter-spacing: -1.5px;
        }
        
        /* Unified input group focus styling */
        .input-group:focus-within {
            box-shadow: 0 0 0 4px rgba(30, 58, 138, 0.15); /* Themed */
            border-radius: 8px;
        }
        .form-control:focus {
            background-color: #fff !important;
            border-color: transparent !important;
            box-shadow: none !important; /* Let the group handle the shadow */
        }
        .input-group-text {
            background-color: #f8fafc;
        }
        
        .btn-primary {
            background-color: var(--primary-blue); /* Themed */
            border: none;
            transition: all 0.3s ease;
        }
        .btn-primary:hover {
            background-color: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(30, 58, 138, 0.3);
        }
    </style>
</head>
<body>

    <div class="card login-card p-4 p-md-5 bg-white">
        <div class="text-center mb-5">
            <div class="brand-logo mb-1">Pariksha</div>
            <p class="text-muted small fw-medium">Secure • Smart • Seamless</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger border-0 small fw-bold mb-4 rounded-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> <%= error %>
            </div>
        <% } %>
        
        <form action="/login" method="POST">
            <div class="mb-4">
                <label class="form-label small fw-bold text-dark mb-2">Email Address</label>
                <div class="input-group border rounded-3 overflow-hidden">
                    <span class="input-group-text border-0 text-muted px-3"><i class="bi bi-envelope"></i></span>
                    <input type="email" name="email" class="form-control bg-light border-0 py-2" placeholder="student@example.com" required>
                </div>
            </div>
            <div class="mb-5">
                <label class="form-label small fw-bold text-dark mb-2">Password</label>
                <div class="input-group border rounded-3 overflow-hidden">
                    <span class="input-group-text border-0 text-muted px-3"><i class="bi bi-lock"></i></span>
                    <input type="password" name="password" id="passwordInput" class="form-control bg-light border-0 py-2" placeholder="••••••••" required>
                    <button class="btn bg-light border-0 px-3" type="button" onclick="togglePassword()">
                        <i class="bi bi-eye text-muted" id="toggleIcon"></i>
                    </button>
                </div>
            </div>
            
            <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow-sm rounded-3 fs-6">
                Sign In <i class="bi bi-arrow-right ms-2"></i>
            </button>
        </form>

        <div class="mt-4 text-center">
            <p class="small text-muted">New student? <a href="/signup" class="fw-bold text-decoration-none" style="color: var(--primary-blue);">Register here</a></p>
            <div class="border-top pt-4 mt-4">
                <p class="small text-muted mb-0">Project Pariksha &copy; 2026</p>
            </div>
        </div>
    </div>

  <script>
    const urlParams = new URLSearchParams(window.location.search);
    const themeColor = '#1E3A8A'; // Matches --primary-blue
    
    // Handle Registration Success
    if (urlParams.has('registered')) {
        Swal.fire({
            icon: 'success',
            title: 'Registration Successful!',
            text: 'You can now log in with your credentials.',
            confirmButtonColor: themeColor,
            heightAuto: false, 
            timer: 4000,
            timerProgressBar: true,
            customClass: { popup: 'rounded-4' }
        });
    }

    // Handle Login Errors
    if (urlParams.get('error') === 'invalid') {
        Swal.fire({
            icon: 'error',
            title: 'Login Failed',
            text: 'Invalid email or password. Please try again.',
            confirmButtonColor: themeColor,
            heightAuto: false,
            customClass: { popup: 'rounded-4' }
        });
    } else if (urlParams.get('error') === 'inactive') {
        Swal.fire({
            icon: 'warning',
            title: 'Account Inactive',
            text: 'Your account is currently disabled. Please contact the administrator.',
            confirmButtonColor: themeColor,
            heightAuto: false,
            customClass: { popup: 'rounded-4' }
        });
    } else if (urlParams.get('error') === 'server') {
        Swal.fire({
            icon: 'info',
            title: 'System Error',
            text: 'Something went wrong on our end. Please try again later.',
            confirmButtonColor: themeColor,
            heightAuto: false,
            customClass: { popup: 'rounded-4' }
        });
    }

    // Clean the URL so the popup doesn't reappear on refresh
    window.history.replaceState({}, document.title, "/login");

    // Password Toggle Function
    function togglePassword() {
        const input = document.getElementById('passwordInput');
        const icon = document.getElementById('toggleIcon');
        if (input.type === "password") {
            input.type = "text";
            icon.classList.replace('bi-eye', 'bi-eye-slash');
        } else {
            input.type = "password";
            icon.classList.replace('bi-eye-slash', 'bi-eye');
        }
    }
</script>

</body>
</html>