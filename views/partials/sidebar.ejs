<div class="col-md-2 d-none d-md-flex flex-column sidebar shadow">
    <div class="mb-5 mt-2 ps-2">
        <h4 class="fw-bold text-white d-flex align-items-center">
            <i class="bi bi-pen-fill me-2"></i>
            Pariksha
        </h4>
        <small class="text-white-50">Admin Control Panel</small>
    </div>

    <nav class="nav flex-column gap-1 flex-grow-1">
        <a class="nav-link <%= (currentPage === 'dashboard') ? 'active' : '' %>" href="/admin/dashboard">
            <i class="bi bi-speedometer2 me-2"></i> Dashboard
        </a>
        <a class="nav-link <%= (currentPage === 'courses') ? 'active' : '' %>" href="/admin/courses">
            <i class="bi bi-mortarboard me-2"></i> Courses
        </a>
        <a class="nav-link <%= (currentPage === 'subjects') ? 'active' : '' %>" href="/admin/subjects">
            <i class="bi bi-book me-2"></i> Subjects
        </a>
        <a class="nav-link <%= (currentPage === 'exams') ? 'active' : '' %>" href="/admin/exams">
            <i class="bi bi-journal-text me-2"></i> Exams
        </a>
        <a class="nav-link <%= (currentPage === 'results') ? 'active' : '' %>" href="/admin/results">
            <i class="bi bi-graph-up-arrow me-2"></i> Results
        </a>

        <hr class="my-4 opacity-25">

        <% if (user && user.role === 'admin') { %>
            <a class="nav-link <%= (currentPage === 'staff') ? 'active' : '' %>" href="/admin/staff">
                <i class="bi bi-people me-2"></i> Manage Staff
            </a>
            <a class="nav-link <%= (currentPage === 'students') ? 'active' : '' %>" href="/admin/students">
                <i class="bi bi-person-badge me-2"></i> Manage Students
            </a>
        <% } %>

        <a class="nav-link nav-logout mt-auto mb-3" href="/logout">
            <i class="bi bi-box-arrow-right me-2"></i> Logout
        </a>
    </nav>
</div>