<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('partials/head') %>
    <title>Student Registration | Pariksha</title>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            /* Matched the background gradient to the login page */
            background: linear-gradient(135deg, #0f172a 0%, var(--primary-blue) 100%);
            margin: 0;
            padding: 40px 0;
            font-family: 'Inter', sans-serif;
        }

        .signup-card {
            max-width: 550px;
            width: 90%;
            border-radius: 24px;
            border: none;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            transition: transform 0.3s ease;
        }

        .signup-card:hover {
            transform: translateY(-5px);
        }

        .brand-logo {
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--primary-blue); /* Themed */
            letter-spacing: -1px;
        }

        /* Unified input group focus styling from login.ejs */
        .input-group:focus-within {
            box-shadow: 0 0 0 4px rgba(30, 58, 138, 0.15);
            border-radius: 8px;
        }
        
        .form-control:focus, .form-select:focus {
            background-color: #fff !important;
            border-color: transparent !important;
            box-shadow: none !important;
        }

        .input-group-text {
            background-color: #f8fafc;
        }

        .btn-primary {
            background-color: var(--primary-blue); /* Themed */
            border: none;
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            background-color: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(30, 58, 138, 0.3);
        }

        .form-select {
            cursor: pointer;
        }
        
        .year-radio-container {
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 12px;
            background-color: #f8fafc;
        }
    </style>
</head>

<body>

    <div class="card signup-card p-4 p-md-5 bg-white">
        <div class="text-center mb-4">
            <div class="brand-logo mb-1">Join Pariksha</div>
            <p class="text-muted small fw-medium">Create your student account</p>
        </div>

        <form action="/signup" method="POST" id="registrationForm">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label small fw-bold text-dark mb-2">First Name</label>
                    <div class="input-group border rounded-3 overflow-hidden">
                        <span class="input-group-text border-0 text-muted px-3"><i class="bi bi-person"></i></span>
                        <input type="text" name="first_name" class="form-control bg-light border-0 py-2" placeholder="John" required>
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label small fw-bold text-dark mb-2">Last Name</label>
                    <div class="input-group border rounded-3 overflow-hidden">
                        <span class="input-group-text border-0 text-muted px-3"><i class="bi bi-person"></i></span>
                        <input type="text" name="last_name" class="form-control bg-light border-0 py-2" placeholder="Doe" required>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold text-dark mb-2">Email Address</label>
                <div class="input-group border rounded-3 overflow-hidden">
                    <span class="input-group-text border-0 text-muted px-3"><i class="bi bi-envelope"></i></span>
                    <input type="email" name="email" class="form-control bg-light border-0 py-2" placeholder="student@example.edu" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold text-dark mb-2">Select Course / Class</label>
                <div class="input-group border rounded-3 overflow-hidden">
                    <span class="input-group-text border-0 text-muted px-3"><i class="bi bi-mortarboard"></i></span>
                    <select name="class_name" class="form-select bg-light border-0 py-2" required>
                        <option value="" selected disabled>Choose your academic department...</option>
                        <% if (courses && courses.length > 0) { %>
                            <% courses.forEach(course => { %>
                                <option value="<%= course.course_name %>"><%= course.course_name %></option>
                            <% }) %>
                        <% } else { %>
                            <option disabled>No courses available. Contact Admin.</option>
                        <% } %>
                    </select>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold text-dark mb-2">Academic Year</label>
                <div class="year-radio-container">
                    <div class="row g-2">
                        <div class="col-12 col-md-4">
                            <div class="form-check d-flex align-items-center mb-0">
                                <input class="form-check-input mt-0" type="radio" name="year_code" id="fy" value="FY" checked required>
                                <label class="form-check-label ms-2 small fw-medium" for="fy">First Year</label>
                            </div>
                        </div>
                        <div class="col-12 col-md-4">
                            <div class="form-check d-flex align-items-center mb-0">
                                <input class="form-check-input mt-0" type="radio" name="year_code" id="sy" value="SY">
                                <label class="form-check-label ms-2 small fw-medium" for="sy">Second Year</label>
                            </div>
                        </div>
                        <div class="col-12 col-md-4">
                            <div class="form-check d-flex align-items-center mb-0">
                                <input class="form-check-input mt-0" type="radio" name="year_code" id="ty" value="TY">
                                <label class="form-check-label ms-2 small fw-medium" for="ty">Third Year</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold text-dark mb-2">Create Password</label>
                <div class="input-group border rounded-3 overflow-hidden">
                    <span class="input-group-text border-0 text-muted px-3"><i class="bi bi-lock"></i></span>
                    <input type="password" name="password" class="form-control bg-light border-0 py-2" placeholder="••••••••" required>
                </div>
            </div>

            <button type="submit" id="signupBtn" class="btn btn-primary w-100 py-3 fw-bold shadow-sm rounded-3 fs-6">
                <span id="btnText">Register Student</span>
                <div id="btnSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status"></div>
                <i id="btnIcon" class="bi bi-person-plus-fill ms-2"></i>
            </button>
        </form>

        <div class="mt-4 text-center">
            <p class="small text-muted mb-0">Already have an account? <a href="/login" class="fw-bold text-decoration-none" style="color: var(--primary-blue);">Sign In</a></p>
        </div>
    </div>

    <script>
        const signupForm = document.getElementById('registrationForm');
        const signupBtn = document.getElementById('signupBtn');
        const btnText = document.getElementById('btnText');
        const btnSpinner = document.getElementById('btnSpinner');
        const btnIcon = document.getElementById('btnIcon');
        const themeColor = '#1E3A8A'; // For SweetAlert

        // Handle the Loading State on Submit
        signupForm.addEventListener('submit', function () {
            signupBtn.disabled = true;
            btnText.innerText = "Processing...";
            btnSpinner.classList.remove('d-none');
            btnIcon.classList.add('d-none');
        });

        // Error Handling for duplicate emails
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('error') === 'exists') {
            Swal.fire({
                icon: 'warning',
                title: 'Account Exists',
                text: 'This email is already associated with an account. Please try logging in instead.',
                confirmButtonColor: themeColor, // Themed
                footer: `<a href="/login" style="color: ${themeColor}; text-decoration: none; font-weight: bold;">Go to Login Page</a>`,
                customClass: { popup: 'rounded-4' }
            });
            window.history.replaceState({}, document.title, "/signup");
        }
    </script>

</body>

</html>