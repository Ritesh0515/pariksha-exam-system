<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Exam Instructions | Pariksha</title>
    <style>
        :root {
            --primary-blue: #1E3A8A;
            --primary-hover: #172e6e;
        }

        .instruction-card {
            border-radius: 24px;
            background: #ffffff;
            border: 1px solid #e2e8f0;
        }

        /* Themed Stat Badges */
        .stat-badge {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 20px 10px;
            text-align: center;
            transition: all 0.3s ease;
        }
        .stat-badge:hover {
            border-color: var(--primary-blue);
            background: #fff;
            transform: translateY(-3px);
        }
        .stat-value {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--primary-blue);
            display: block;
            line-height: 1.2;
        }
        .stat-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 1px;
            color: #64748b;
            margin-top: 5px;
            display: block;
        }

        /* Rule Items */
        .rule-item {
            border-left: 4px solid var(--primary-blue);
            background-color: #f8fafc;
            padding: 15px 20px;
            border-radius: 0 12px 12px 0;
            margin-bottom: 12px;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            color: #334155;
        }
        .rule-item i {
            font-size: 1.25rem;
            margin-right: 15px;
            color: var(--primary-blue);
        }
        
        .rule-warning {
            border-left-color: #ef4444;
            background-color: #fef2f2;
        }
        .rule-warning i {
            color: #ef4444;
        }

        .btn-start {
            background-color: var(--primary-blue);
            border: none;
            transition: all 0.3s ease;
        }
        .btn-start:hover {
            background-color: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -5px rgba(30, 58, 138, 0.4);
        }
    </style>
</head>
<body class="bg-light">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-7 col-md-9">
                <div class="card instruction-card p-4 p-md-5 border-0 shadow-lg">
                    
                    <div class="text-center mb-5">
                        <div class="d-inline-block px-3 py-2 rounded-pill mb-3" style="background: #E0E7FF; color: var(--primary-blue); font-weight: 700; font-size: 0.85rem;">
                            <i class="bi bi-journal-bookmark-fill me-1"></i> <%= exam.subject_name.toUpperCase() %>
                        </div>
                        <h1 class="fw-bold text-dark mb-2"><%= exam.exam_name %></h1>
                        <p class="text-muted">Please read the following guidelines carefully before starting.</p>
                    </div>

                    <div class="row g-3 mb-5">
                        <div class="col-4">
                            <div class="stat-badge shadow-sm">
                                <span class="stat-value"><%= qCount %></span>
                                <span class="stat-label">MCQs</span>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="stat-badge shadow-sm">
                                <span class="stat-value"><%= exam.duration_minutes %>m</span>
                                <span class="stat-label">Timer</span>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="stat-badge shadow-sm">
                                <span class="stat-value">Set <%= assignedSet || 'A' %></span>
                                <span class="stat-label">Question Set</span>
                            </div>
                        </div>
                    </div>

                    <h5 class="fw-bold text-dark mb-3"><i class="bi bi-shield-check me-2 text-primary"></i>Examination Rules</h5>
                    <div class="mb-5">
                        <div class="rule-item">
                            <i class="bi bi-clock-history"></i>
                            <span>The timer starts the moment you click 'Start'. It cannot be paused.</span>
                        </div>
                        <div class="rule-item rule-warning">
                            <i class="bi bi-exclamation-octagon"></i>
                            <span>Leaving the window or switching tabs more than <strong>3 times</strong> triggers automatic submission.</span>
                        </div>
                        <div class="rule-item">
                            <i class="bi bi-arrow-repeat"></i>
                            <span>Do not refresh the page. Your progress is saved, but the timer keeps running.</span>
                        </div>
                        <div class="rule-item">
                            <i class="bi bi-wifi"></i>
                            <span>Ensure a stable internet connection for the duration of the exam.</span>
                        </div>
                    </div>

                    <div class="d-grid gap-3">
                        <a href="/student/exam/<%= exam.exam_id %>/attempt" class="btn btn-primary btn-lg shadow btn-start rounded-pill py-3 fw-bold">
                            Begin Assessment <i class="bi bi-play-circle-fill ms-2"></i>
                        </a>
                        <a href="/student/dashboard" class="btn btn-link text-muted text-decoration-none small text-center">
                            <i class="bi bi-arrow-left me-1"></i> Return to Dashboard
                        </a>
                    </div>

                    <div class="mt-5 pt-3 border-top text-center">
                        <p class="small text-muted mb-0">Pariksha Examination System &bull; Secured Browser Monitoring Active</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>