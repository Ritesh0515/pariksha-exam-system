<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title><%= title %> | Pariksha</title>
    <style>
        .message-card {
            border: none;
            border-radius: 1.5rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        .icon-circle {
            width: 80px;
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            margin: 0 auto 1.5rem;
        }
    </style>
</head>
<body class="bg-light d-flex align-items-center vh-100">

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5 text-center">
                <div class="card message-card p-5">
                    <div class="icon-circle bg-<%= type %>-subtle text-<%= type %>">
                        <i class="bi <%= type === 'danger' ? 'bi-exclamation-octagon' : 'bi-info-circle' %> fs-1"></i>
                    </div>
                    
                    <h2 class="fw-bold text-dark mb-3"><%= title %></h2>
                    <p class="text-muted mb-4 lead"><%= message %></p>
                    
                    <div class="d-grid gap-2">
                        <a href="/student/dashboard" class="btn btn-primary rounded-pill py-2 fw-bold shadow-sm">
                            Return to Dashboard
                        </a>
                        <button onclick="location.reload()" class="btn btn-link text-decoration-none text-muted small">
                            <i class="bi bi-arrow-clockwise"></i> Try Again
                        </button>
                    </div>
                </div>
                <p class="mt-4 text-muted small">&copy; 2026 Pariksha Examination System</p>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>